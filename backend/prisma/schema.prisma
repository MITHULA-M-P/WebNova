generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            Int           @id @default(autoincrement())
  business_name String?
  email         String        @unique
  phone         String
  created_at    DateTime      @default(now())
  bookings      Booking[]
  plans         WebsitePlan[]

  @@map("customers")
}

model WebsitePlan {
  id            Int       @id @default(autoincrement())
  customer_id   Int
  website_type  String
  business_goal String
  pages         Int
  budget        Float
  brand_color   String?
  has_logo      Boolean   @default(false)
  created_at    DateTime  @default(now())
  features      Feature[]
  customer      Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("website_plans")
}

model Feature {
  id           Int         @id @default(autoincrement())
  plan_id      Int
  feature_name String
  plan         WebsitePlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("features")
}

model Booking {
  id           Int      @id @default(autoincrement())
  customer_id  Int
  booking_date String
  booking_time String
  status       String   @default("pending")
  message      String?
  created_at   DateTime @default(now())
  customer     Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model Admin {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  created_at DateTime @default(now())

  @@map("admins")
}

model TimeSlot {
  id          Int      @id @default(autoincrement())
  day_of_week String   @default("all") // e.g. "Monday", "Tuesday", or "all"
  start_time  String   // e.g. "10:00 AM"
  end_time    String   // e.g. "11:00 AM"
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("time_slots")
}

model Portfolio {
  id           Int      @id @default(autoincrement())
  title        String
  description  String
  category     String
  technologies String   // Comma-separated or JSON string
  image_url    String
  github_url   String?
  live_url     String?
  is_featured  Boolean  @default(false)
  created_at   DateTime @default(now())

  @@map("portfolios")
}

model PricingPlan {
  id            Int              @id @default(autoincrement())
  title         String
  description   String
  price         Float
  billing_cycle String           @default("one-time") // "one-time", "monthly", "yearly"
  is_active     Boolean          @default(true)
  is_popular    Boolean          @default(false)
  features      PricingFeature[]
  created_at    DateTime         @default(now())

  @@map("pricing_plans")
}

model PricingFeature {
  id           Int         @id @default(autoincrement())
  plan_id      Int
  feature_name String
  is_included  Boolean     @default(true)
  plan         PricingPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("pricing_features")
}

model WebsiteSettings {
  id             Int      @id @default(autoincrement())
  company_name   String   @default("WebNova")
  hero_title     String   @default("We Build High-Converting Custom Websites")
  hero_subtitle  String   @default("Transforming your digital presence with modern web design, seamless development, and optimized conversion strategies.")
  about_text     String   @default("WebNova is a premier digital web agency specializing in ultra-modern web application development, brand strategy, and bespoke digital experiences.")
  contact_email  String   @default("contact@webnova.in")
  phone_number   String   @default("+91 98765 43210")
  office_address String   @default("123 Tech Park, Innovation Way, Bangalore, India")
  social_twitter String?  @default("https://twitter.com/webnova")
  social_github  String?  @default("https://github.com/webnova")
  social_linkedin String? @default("https://linkedin.com/company/webnova")
  social_instagram String? @default("https://instagram.com/webnova")
  footer_text    String   @default("© 2026 WebNova Studio. All rights reserved.")
  logo_url       String?
  favicon_url    String?
  updated_at     DateTime @updatedAt

  @@map("website_settings")
}

model Statistic {
  id            Int      @id @default(autoincrement())
  label         String
  value         String
  prefix        String?  @default("")
  suffix        String?  @default("")
  icon          String?  @default("📊")
  display_order Int      @default(0)
  created_at    DateTime @default(now())

  @@map("statistics")
}
